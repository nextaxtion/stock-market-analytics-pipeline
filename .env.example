# Copy this file to .env and fill in your values.
# Load it before running scripts: source .env   (or use direnv)
# Never commit the actual .env file — it contains secrets.

# ── GCP ──────────────────────────────────────────────────────────────────────
# Your GCP project ID (visible in the GCP console top bar)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket name created by Terraform (terraform output gcs_bucket_name)
GCS_BUCKET=your-gcs-bucket-name

# BigQuery dataset (created by Terraform)
BQ_DATASET=dezoomcampds

# BigQuery / GCS region — must be the same for data transfers
BQ_LOCATION=us-central1

# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# ── Kaggle ───────────────────────────────────────────────────────────────────
# Kaggle API credentials (from https://www.kaggle.com/settings → API)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ── Airflow (Cloud Composer) ─────────────────────────────────────────────────
# Absolute path to the cloned repo on the Composer worker
REPO_DIR=/opt/stock-market-analytics-pipeline
